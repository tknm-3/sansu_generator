{
  "env": {
    "PLAYWRIGHT_BROWSERS_PATH": "/opt/pw-browsers"
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(*)",
      "PowerShell(*)",
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(python *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(Get-ChildItem *)",
      "Bash(New-Item *)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep"
    ]
  },
  "language": "japanese",
  "skillListingMaxDescChars": 400,
  "skillOverrides": {
    "anthropic-skills:docx": "name-only",
    "anthropic-skills:pdf": "name-only",
    "anthropic-skills:pptx": "name-only",
    "anthropic-skills:xlsx": "name-only",
    "anthropic-skills:setup-cowork": "name-only"
  }
}
